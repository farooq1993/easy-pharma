{
  "version": 2,
  "builds": [
    {
      "src": "pharmaProject/wsgi.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.12" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "pharmaProject/wsgi.py"
    }
  ],
  "functions": {
    "manage.py": {
      "maxDuration": 300,
      "memory": 1024
    }
  }
}
